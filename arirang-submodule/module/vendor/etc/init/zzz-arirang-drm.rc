# --- HIDL 1.1 / 1.0 fallbacks --------------------------------------------
service vendor.drm-hal-1-1-widevine /vendor/bin/hw/android.hardware.drm@1.1-service.widevine
    override
    interface android.hardware.drm@1.1::ICryptoFactory widevine
    interface android.hardware.drm@1.1::IDrmFactory widevine
    class hal
    user mediadrm
    group mediadrm drmrpc
    setenv LD_PRELOAD /system/lib64/libarirang_drm_hook.so

service vendor.drm-hal-1-0-widevine /vendor/bin/hw/android.hardware.drm@1.0-service.widevine
    override
    interface android.hardware.drm@1.0::ICryptoFactory widevine
    interface android.hardware.drm@1.0::IDrmFactory widevine
    class hal
    user mediadrm
    group mediadrm drmrpc
    setenv LD_PRELOAD /system/lib64/libarirang_drm_hook.so
