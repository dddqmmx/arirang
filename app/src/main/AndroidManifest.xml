<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- 基础权限 -->
    <uses-permission android:name="android.permission.QUERY_PACKAGES" />
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="PackageVisibilityPolicy,QueryAllPackagesPermission" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_PHONE_NUMBERS" />
    <uses-permission
        android:name="android.permission.READ_PRIVILEGED_PHONE_STATE"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" /> <!-- 弹窗与后台启动相关权限 -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" /> <!-- 关键：用于全屏通知 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" /> <!-- 关键：Android 13+ 发送通知必须 -->
    <!-- 前台服务相关 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!--
      注意：如果你要让 system_server 绑定，不要给 Service 加签名权限保护。
      或者将 protectionLevel 改为 "normal"，但建议直接在 Service 标签中去掉权限限制。
    -->
    <permission
        android:name="asia.nana7mi.arirang.BIND_NOTIFY"
        android:protectionLevel="normal" />

    <application
        android:name=".ArirangApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Arirang">
        <service
            android:name=".service.HookNotifyService"
            android:exported="true"
            android:foregroundServiceType="specialUse">
            <intent-filter>
                <action android:name="asia.nana7mi.arirang.BIND_NOTIFY" />
            </intent-filter>
            <!-- Android 14+ 要求对 specialUse 进行说明 -->
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FQS_SUBTYPE"
                android:value="Hook service for permission monitoring" />
        </service>
        <!--
            修复点 3: 对话框 Activity。
            为了保证能从后台弹出，建议在 ActivityOptions 中做处理，
            或者确保用户已经手动授权了“显示在其他应用上层” (SYSTEM_ALERT_WINDOW)。
        -->
        <activity
            android:name=".ui.ConfirmDialogActivity"
            android:excludeFromRecents="true"
            android:exported="true"
            android:launchMode="singleInstance"
            android:showForAllUsers="true"
            android:taskAffinity=""
            android:theme="@style/Theme.AppCompat.Dialog.Alert" />
        <activity
            android:name=".ui.SimScopeActivity"
            android:exported="false" />
        <activity
            android:name=".ui.LocationConfigActivity"
            android:exported="false" />
        <activity
            android:name=".ui.SimConfigActivity"
            android:exported="false" />
        <activity
            android:name=".ui.PackageListConfigActivity"
            android:exported="false" />
        <activity
            android:name=".ui.TestActivity"
            android:exported="false" />
        <activity
            android:name=".ui.DeviceInfoConfigActivity"
            android:exported="false" />
        <activity
            android:name=".ui.LanguageSettingsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.ClipboardConfigActivity"
            android:exported="false" /> <!-- Xposed 模块配置 -->
        <meta-data
            android:name="xposedmodule"
            android:value="true" />
        <meta-data
            android:name="xposeddescription"
            android:value="For testing only" />
        <meta-data
            android:name="xposedminversion"
            android:value="93" />
        <meta-data
            android:name="xposedscope"
            android:resource="@array/xposedscope" />
        <!-- 1. 设置 SplashActivity 为启动页 (Launcher) -->
        <activity
            android:name=".ui.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".ui.MainActivity"
            android:exported="false"/>
        <activity
            android:name=".ui.InitActivity"
            android:exported="true"/>
    </application>

</manifest>