<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/rootLayout"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- 首页标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_home"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <!-- 状态卡片 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/status_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:background="?attr/colorSurface"
            style="@style/Widget.Material3.CardView.Filled">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_title"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorOnSurface"/>

                <TextView
                    android:id="@+id/status_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/status_deactivated"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

        </androidx.cardview.widget.CardView>


        <!-- 权限 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/category_permission"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <asia.nana7mi.arirang.view.FeatureItemView
                android:id="@+id/clipboard_setting_bottom"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:featureName="@string/feature_clipboard" />

            <Space
                android:layout_width="12dp"
                android:layout_height="match_parent" />

            <asia.nana7mi.arirang.view.FeatureItemView
                android:id="@+id/sensor_info_setting_bottom"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:featureName="@string/feature_sensor_info" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <asia.nana7mi.arirang.view.FeatureItemView
                android:id="@+id/bluetooth_list_bottom"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:featureName="@string/feature_bluetooth_list" />

            <Space
                android:layout_width="12dp"
                android:layout_height="match_parent" />

            <asia.nana7mi.arirang.view.FeatureItemView
                android:id="@+id/wifi_setting_bottom"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:featureName="@string/feature_wifi_list" />
        </LinearLayout>


        <!-- 篡改 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/category_anonymization"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <asia.nana7mi.arirang.view.FeatureItemView
                    android:id="@+id/package_list_bottom"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:featureName="@string/feature_app_list" />

                <Space
                    android:layout_width="12dp"
                    android:layout_height="match_parent" />

                <asia.nana7mi.arirang.view.FeatureItemView
                    android:id="@+id/sim_info_setting_bottom"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:featureName="@string/feature_sim_info" />
            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <asia.nana7mi.arirang.view.FeatureItemView
                    android:id="@+id/location_setting_bottom"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:featureName="@string/feature_location" />

                <Space
                    android:layout_width="12dp"
                    android:layout_height="match_parent" />

                <asia.nana7mi.arirang.view.FeatureItemView
                    android:id="@+id/device_info_setting_bottom"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:featureName="@string/feature_device_info" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <asia.nana7mi.arirang.view.FeatureItemView
                    android:id="@+id/unique_identifier_setting_bottom"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:featureName="@string/feature_unique_identifier" />

                <Space
                    android:layout_width="12dp"
                    android:layout_height="match_parent" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />
            </LinearLayout>

        </LinearLayout>


        <!-- 审计 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/category_audit"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginBottom="8dp"/>

        <asia.nana7mi.arirang.view.FeatureItemView
            android:id="@+id/test_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:featureName="@string/feature_permission_stats" />

    </LinearLayout>

</ScrollView>
