<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <Button
            android:id="@+id/btn_refresh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/refresh_all_data"
            android:layout_marginBottom="16dp" />

        <!-- 原生部分 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/native_android_api"
            android:textStyle="bold"
            android:textColor="#FF0000" />

        <TextView
            android:id="@+id/tv_native_cache"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:background="#F0F0F0"
            android:text="@string/native_cache_waiting"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_native_real"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:background="#E0E0E0"
            android:text="@string/native_realtime_waiting"
            android:layout_marginBottom="16dp"/>

        <!-- Fused 部分 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/google_fused_location_api"
            android:textStyle="bold"
            android:textColor="#0000FF" />

        <TextView
            android:id="@+id/tv_fused_cache"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:background="#F0F0F0"
            android:text="@string/fused_cache_waiting"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_fused_real"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:background="#E0E0E0"
            android:text="@string/fused_realtime_waiting" />

    </LinearLayout>
</ScrollView>