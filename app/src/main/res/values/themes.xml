<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.Arirang" parent="Theme.Material3.DayNight.NoActionBar">

        <item name="android:windowLightStatusBar">?attr/isLightTheme</item>

        <item name="android:statusBarColor">@android:color/transparent</item>

        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>

        <item name="android:windowSplashScreenBackground">?attr/colorSurface</item>

    </style>

    <style name="Theme.Arirang" parent="Base.Theme.Arirang" />

    <style name="Theme.Arirang.Transparent" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.5</item>
    </style>
</resources>